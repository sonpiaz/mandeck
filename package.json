{
  "name": "mandeck",
  "version": "0.1.1",
  "description": "A Liquid Glass terminal multiplexer for macOS \u2014 workspaces, tiled panes, and a design that belongs on Tahoe.",
  "author": "Son Piaz",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sonpiaz/mandeck.git"
  },
  "productName": "Mandeck",
  "private": true,
  "main": "dist-electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "rebuild": "electron-rebuild -f -w node-pty",
    "test:migration": "node scripts/test-migration.mjs",
    "postinstall": "electron-rebuild -f -w node-pty || echo 'rebuild skipped'",
    "dist": "npm run build && electron-builder --mac --arm64 --dir"
  },
  "build": {
    "appId": "dev.mandeck.next",
    "productName": "Mandeck",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dir",
          "arch": [
            "arm64"
          ]
        }
      ],
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "extendInfo": {
        "CFBundleIconName": "Mandeck"
      }
    },
    "asar": true,
    "extraResources": [
      {
        "from": "build/icon/Assets.car",
        "to": "."
      }
    ]
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-webgl": "^0.18.0",
    "@xterm/xterm": "^5.5.0",
    "allotment": "^1.20.2",
    "node-pty": "^1.0.0",
    "react": "^18.3.1",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.0",
    "@types/node": "^22.5.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.0"
  }
}